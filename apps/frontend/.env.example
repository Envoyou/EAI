# VPS Backend API URL (Next.js client/server proxies calls here)
NEXT_PUBLIC_API_URL="http://localhost:5001"

# Clerk Authentication Keys (Client and Server)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"

# Clerk SignIn / SignUp Redirections
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/workspace"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Next.js Middleware Bypass Edge Config (For feature flag checks in middleware)
EDGE_CONFIG=""

# Public Rollout Feature Flags (Baked in at compile time)
NEXT_PUBLIC_DEMO_ENABLED="true"
NEXT_PUBLIC_SIGNUP_ENABLED="true"
NEXT_PUBLIC_PRICING_ENABLED="true"
NEXT_PUBLIC_BILLING_ENABLED="false"

# Public Legal Identity Configurations
LEGAL_OPERATOR_NAME="Envoyou"
LEGAL_REGISTERED_ADDRESS=""
LEGAL_SUPPORT_EMAIL="support@envoyou.com"
LEGAL_CONTACT_EMAIL="info@envoyou.com"
LEGAL_PRIVACY_EMAIL="support@envoyou.com"
LEGAL_GOVERNING_LAW="the laws of Indonesia"

# Comma-separated Clerk user IDs allowed to access owner-only internal tools.
OWNER_USER_IDS="user_your_owner_clerk_id"
