{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "npx tsc && npx tsc-alias",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@clerk/backend": "^1.24.1",
    "@eai/shared": "*",
    "@google/genai": "^2.6.0",
