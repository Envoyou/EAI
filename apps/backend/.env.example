# Port for Express server
PORT=5001
NODE_ENV=development

# Neon Database Connection
DATABASE_URL="postgres://user:password@endpoint-pooler.neon.tech/neondb?pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgres://user:password@endpoint.neon.tech/neondb?connect_timeout=15"

# Clerk Secret Key (Get from https://dashboard.clerk.com)
CLERK_SECRET_KEY="your-clerk-secret-key"
CLERK_WEBHOOK_SECRET="your-clerk-webhook-secret"

# Active AI provider (gemini | groq)
ACTIVE_AI_PROVIDER="gemini"

# Gemini API Key (primary provider)
GEMINI_API_KEY="your-gemini-api-key"

# Groq API Key (optional provider)
GROQ_API_KEY="your-groq-api-key"

# AI cost analytics. Token usage comes from providers; IDR cost is estimated.
AI_COST_USD_TO_IDR="17779.30"

# Comma-separated Clerk user IDs allowed to access owner-only internal tools.
OWNER_USER_IDS="user_your_owner_clerk_id"

# Optional Zoho Desk validation for manual billing adjustments.
ZOHO_DESK_ENABLED="false"
ZOHO_DESK_CLIENT_ID=""
ZOHO_DESK_CLIENT_SECRET=""
ZOHO_DESK_REFRESH_TOKEN=""
ZOHO_DESK_ORG_ID=""
ZOHO_DESK_DEPARTMENT_ID=""
ZOHO_ACCOUNTS_URL="https://accounts.zoho.com"
ZOHO_DESK_API_URL="https://desk.zoho.com/api/v1"

# Edge Config (Feature Flags) Server Credentials
EDGE_CONFIG=""
EDGE_CONFIG_ID=""
VERCEL_API_TOKEN=""
VERCEL_TEAM_ID=""

# Export Pipeline Settings
BLOG_IMPORT_SHARED_SECRET=""
BLOG_BACKEND_API_URL="your-blog-backend-api-url"

# Encrypts tenant CMS credentials at rest.
CMS_CREDENTIALS_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Shared secret token for public stats integration
PUBLIC_STATS_TOKEN=""

# Payment gateway configuration
PAYMENT_PROVIDER="midtrans"
PAYMENT_USD_TO_IDR_RATE="17779.30"
PAYMENT_TAX_LABEL="Tax is not separately itemized in the displayed checkout amount."

# Midtrans Snapchat Credentials
MIDTRANS_SERVER_KEY="SB-Mid-server-your-sandbox-server-key"
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_ENABLE_SIMULATOR="false"
MIDTRANS_SIMULATOR_SECRET="replace-with-a-long-random-local-secret"

REDIS_URL=
